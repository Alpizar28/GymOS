TELEGRAM_BOT_TOKEN=your_token_here     # REMOVED — web-only mode
OPENAI_API_KEY=your_openai_key_here
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/postgres
DATABASE_STATEMENT_CACHE_SIZE=0
LOG_LEVEL=INFO
PORT=8000
WEB_URL=https://your-frontend-domain.sslip.io
AUTH_ENABLED=true
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
DEV_FALLBACK_USER_ID=00000000-0000-0000-0000-000000000001

# Frontend proxy/backend discovery
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_BACKEND_URL=http://backend:8000
PROXY_TIMEOUT_MS=60000

# Frontend Supabase client
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_AUTH_BYPASS=false

# Optional/admin scripts
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
